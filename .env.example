# InTheMoment environment variables.
# Copy to `.env` for local use. Do NOT commit real secrets.

# ── iOS app ────────────────────────────────────────────────────────────────
# Override the API base URL the app talks to. Defaults to the live Fly server.
# Set this in the Xcode scheme (Product > Scheme > Edit Scheme > Run > Arguments
# > Environment Variables) to point the app at a local server, e.g.:
ITM_API_BASE_URL=http://localhost:8080

# ── Server (Vapor) ─────────────────────────────────────────────────────────
# Where the SQLite database file lives. On Fly this is the mounted volume.
DATABASE_PATH=db.sqlite

# Secret used to sign JWTs. MUST be set to a long random value in production
# (on Fly: `flyctl secrets set JWT_SECRET=$(openssl rand -hex 32)`).
JWT_SECRET=dev-secret-change-me-in-production
